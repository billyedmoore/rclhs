cabal-version:      3.0
-- Generated by `rosidl_generator_hs` part of `rclhs`.

name:               {{package_name_hyphen}}-hs
version:            0.1.0.0

author:             RclHs (Code-Gen)
maintainer:         billyedmoore@yahoo.com

build-type:         Simple

library
    exposed-modules:
    {%- for msg_name in messages %}
        RclHs.{{package_name_pascal}}.Msg.{{msg_name}}
    {%- endfor %}
    build-depends:   
        base ^>=4.18.3.0,
        rclhs
    hs-source-dirs:   src
    default-language: GHC2021
    default-extensions: CApiFFI
    extra-libraries:
        {{ package_name }}__rosidl_typesupport_c
        rosidl_typesupport_c
        rosidl_runtime_c
