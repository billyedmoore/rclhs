cabal-version:      3.0
-- Generated by `rosidl_generator_hs` part of `rclhs`.

name:               {{package_name_hyphen}}-hs
version:            0.1.0.0

author:             RclHs (Code-Gen)
maintainer:         billyedmoore@yahoo.com

build-type:         Simple

library
    exposed-modules:
    {%- for msg_name in messages %}
        RclHs.{{package_name_pascal}}.Msg.{{msg_name}}
    {%- endfor %}
    {%- for service_name in services %}
        RclHs.{{package_name_pascal}}.Srv.{{service_name}}
    {%- endfor %}
    other-modules:
    {%- for service_name in services %}
        RclHs.{{package_name_pascal}}.Srv.{{service_name}}.{{service_name}}_Request
        RclHs.{{package_name_pascal}}.Srv.{{service_name}}.{{service_name}}_Response
    {%- endfor %}
    -- TODO: versions for vector things.
    build-depends:   
        base ^>=4.18.3.0,
        rclhs,
        vector,
        vector-sized
    hs-source-dirs:   src
    default-language: GHC2021
    default-extensions: CApiFFI, DataKinds, TypeFamilies, DuplicateRecordFields
    extra-libraries:
        {{ package_name }}__rosidl_typesupport_c
        {{ package_name }}__rosidl_generator_c
        rosidl_typesupport_c
        rosidl_runtime_c
